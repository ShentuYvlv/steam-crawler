# Backend
DATABASE_URL=postgresql+asyncpg://steam:steam@host.docker.internal:5432/steam_reviews
REDIS_URL=redis://host.docker.internal:6379/0
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
PIP_TRUSTED_HOST=mirrors.aliyun.com
PIP_RETRIES=10
JWT_SECRET_KEY=replace-with-a-long-random-secret
ALIYUN_API_KEY=
ALIYUN_MODEL=qwen-plus
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation
STEAM_COOKIE_FILE=/app/data/steam_cookie.txt
STEAM_REPLY_PROXY_URL=
STEAM_REPLY_PROXY_DIRECT_FALLBACK=false
OXYLABS_PROXY_ENABLED=false
OXYLABS_PROXY_HOST=dc.oxylabs.io
OXYLABS_PROXY_PORT=8000
OXYLABS_PROXY_USERNAME=
OXYLABS_PROXY_PASSWORD=
OXYLABS_PROXY_SCHEME=https
OXYLABS_PROXY_ROTATING_PORT=8000
OXYLABS_PROXY_SESSION_PORT_MIN=8001
OXYLABS_PROXY_SESSION_PORT_MAX=63000
OXYLABS_PROXY_DIRECT_FALLBACK=true
TASK_SCHEDULER_ENABLED=true
TASK_SCHEDULER_POLL_SECONDS=60
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://your-domain.com,https://your-domain.com

# Server bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=管理员
ADMIN_ROLE=admin
STOCK_REVIEWS_APP_ID=3350200
STOCK_REVIEWS_FILE=/app/data/情感反诈模拟器-steam评论 - 全部评论.csv

# Frontend
VITE_API_BASE_URL=/api
FRONTEND_PORT=80
